---
import md5 from 'md5';
import manifest from '../../public/manifest.json';

const formatCoord = (n: number) => n.toFixed(2).padStart(6, '0');

const calculateCoordinates = (url: string) => {
  const domain = new URL(url).hostname.toLowerCase();
  const hash = md5(domain);
  
  const xHex = hash.slice(0, 6);
  const yHex = hash.slice(6, 12);
  const zHex = hash.slice(12, 18);
  
  const xCoord = (parseInt(xHex, 16) % 100000) / 100;
  const yCoord = (parseInt(yHex, 16) % 100000) / 100;
  const zCoord = (parseInt(zHex, 16) % 100000) / 100;
  
  return {
    x: xCoord,
    y: yCoord,
    z: zCoord,
    formatted: `${formatCoord(xCoord)}:${formatCoord(yCoord)}:${formatCoord(zCoord)}`
  };
};

const myCoords = calculateCoordinates(manifest.landing_site);

const traffic = [
    { type: 'preparation', ship: 'X-99-R "Star-Skipper"', status: 'PREPARING', dir: 'to', planetName: 'Solaris Gate', url: 'https://solaris.gate.link', time: 'Dep: 12:00 FY' },
    { type: 'outgoing', ship: 'S-42-X', status: 'DEPARTING', dir: 'to', planetName: 'Aether Reach', url: 'https://aether.reach.io', time: 'Arr: 14:30 FY' },
    { type: 'incoming', ship: 'V-00-Z "The Great Unknown"', status: 'INCOMING', dir: 'from', planetName: 'Nova Prime', url: 'https://nova.prime.core', time: 'ETA: 10m' },
];

const archive = [
    { type: 'arrived', ship: 'A-12-B "Nomad"', status: 'ARRIVED', dir: 'from', planetName: 'Iron Star Forge', url: 'https://ironstar.forge', time: '09:15 FY' },
    { type: 'departed', ship: 'D-45-C "Swift"', status: 'DEPARTED', dir: 'to', planetName: 'Neon Nebula', url: 'https://neon.nebula.web', time: '08:30 FY' },
    { type: 'arrived', ship: 'K-88-M "Crystal Voyager"', status: 'ARRIVED', dir: 'from', planetName: 'Crystal Spire', url: 'https://crystal.spire.planet', time: '07:45 FY' },
    { type: 'departed', ship: 'Z-11-Q "Nova One"', status: 'DEPARTED', dir: 'to', planetName: 'Nova Prime', url: 'https://nova.prime.core', time: '07:00 FY' },
    { type: 'arrived', ship: 'L-33-W "Solar Wind"', status: 'ARRIVED', dir: 'from', planetName: 'Solaris Gate', url: 'https://solaris.gate.link', time: '06:15 FY' },
    { type: 'departed', ship: 'P-55-T "Void Runner"', status: 'DEPARTED', dir: 'to', planetName: 'Void Runner Base', url: 'https://void.runner.base', time: '05:30 FY' },
    { type: 'arrived', ship: 'B-99-F "Bazaar Trader"', status: 'ARRIVED', dir: 'from', planetName: 'Starlight Bazaar', url: 'https://starlight.bazaar.trade', time: '04:45 FY' },
    { type: 'departed', ship: 'M-66-Y "Obsidian Crow"', status: 'DEPARTED', dir: 'to', planetName: 'Obsidian Moon', url: 'https://obsidian.moon.base', time: '04:00 FY' },
    { type: 'arrived', ship: 'H-77-G "Elysium Wing"', status: 'ARRIVED', dir: 'from', planetName: 'Elysium Station', url: 'https://elysium.station.xyz', time: '03:15 FY' },
    { type: 'departed', ship: 'T-22-J "Grip-Cracker"', status: 'DEPARTED', dir: 'to', planetName: 'Titan\'s Grip', url: 'https://titans.grip.mining', time: '02:30 FY' },
];

const warpLinks = [
  { name: 'Aether Reach', url: 'https://aether.reach.io' },
  { name: 'Iron Star Forge', url: 'https://ironstar.forge' },
  { name: 'Neon Nebula', url: 'https://neon.nebula.web' },
  { name: 'Crystal Spire', url: 'https://crystal.spire.planet' },
  { name: 'Rust Belt Outpost', url: 'https://rustbelt.outpost.space' },
  { name: 'Nova Prime', url: 'https://nova.prime.core' },
  { name: 'Solaris Gate', url: 'https://solaris.gate.link' },
  { name: 'Void Runner Base', url: 'https://void.runner.base' },
  { name: 'Starlight Bazaar', url: 'https://starlight.bazaar.trade' },
  { name: 'Obsidian Moon', url: 'https://obsidian.moon.base' },
  { name: 'Elysium Station', url: 'https://elysium.station.xyz' },
  { name: 'Titan\'s Grip', url: 'https://titans.grip.mining' },
  { name: 'Frozen Peak', url: 'https://frozen.peak.outpost' },
  { name: 'Gale Force V', url: 'https://galeforce.five.storm' },
  { name: 'The Monolith', url: 'https://the.monolith.mystery' },
  { name: 'Explorers Outpost', url: 'https://www.nasa.gov/' },
];

const enrichedLinks = warpLinks.map((link, index) => {
    return {
        ...link,
        id: index + 1,
        coords: calculateCoordinates(link.url)
    };
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Landing Site - {manifest.name}</title>
    <link rel="space-manifest" href="/manifest.json" />
    <link rel="stylesheet" href="/planet.css" />
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/0.160.0/three.min.js"></script>
    <script is:inline src="/map.js" defer></script>
  </head>
  <body data-my-x={myCoords.x} data-my-y={myCoords.y} data-my-z={myCoords.z}>
    <div class="planet-container">
      <div class="atmosphere"></div>
      <div class="ring-back"></div>
      <div class="planet"></div>
      <div class="ring"></div>
    </div>
    
    <h1>{manifest.name}</h1>
    <p>{manifest.description}</p>
    <p>
      Coordinates:
      <code class="coord-display">{myCoords.formatted}</code>
    </p>

    <div class="status-badge">Space Port Active</div>

    <section class="space-port">
      <div class="traffic-log">
        <h3>Live Space Port Traffic</h3>
        <table class="traffic-table">
          <thead>
            <tr>
              <th>Ship</th>
              <th>Status</th>
              <th>Location</th>
              <th>Time/ETA</th>
            </tr>
          </thead>
          <tbody>
            {traffic.map(item => {
              const coords = calculateCoordinates(item.url);
              return (
                <tr class={item.type}>
                  <td class="ship-id">{item.ship}</td>
                  <td><span class="status-label">{item.status}</span></td>
                  <td class="location">
                    {item.dir}: {item.planetName}<br />
                    <code class="coord-sm">{coords.formatted}</code>
                  </td>
                  <td class="eta">{item.time}</td>
                </tr>
              )
            })}
          </tbody>
        </table>
      </div>

      <div class="mission-archive">
        <h3>Recent Mission Archive</h3>
        <table class="archive-table">
          <thead>
            <tr>
              <th>Ship</th>
              <th>Event</th>
              <th>Location</th>
              <th>Timestamp</th>
            </tr>
          </thead>
          <tbody>
            {archive.map(item => {
              const coords = calculateCoordinates(item.url);
              return (
                <tr class={item.type}>
                  <td class="ship-id">{item.ship}</td>
                  <td><span class="event-label">{item.status}</span></td>
                  <td class="location">
                    {item.dir}: {item.planetName}<br />
                    <code class="coord-sm">{coords.formatted}</code>
                  </td>
                  <td class="timestamp">{item.time}</td>
                </tr>
              )
            })}
          </tbody>
        </table>
      </div>
    </section>

    <section class="warp-ring">
      <h2>Active Warp Ring Connections</h2>

      <div class="warp-ring-content">
        <div class="star-map-wrapper">
          <div class="star-map-container" id="three-container">
            <div class="map-label">1000x1000x1000 SPARSEC GRID</div>
          </div>

          <div class="map-legend">
            <div class="legend-item">
              <span class="legend-marker station"></span>
              <span>You Are Here</span>
            </div>
            <div class="legend-item">
              <span class="legend-marker neighbor"></span>
              <span>Neighbor Planet</span>
            </div>
          </div>
        </div>

        <ol class="warp-links">
          {enrichedLinks.map(link => (
            <li>
              <a 
                href={link.url}
                data-id={link.id}
                data-x={link.coords.x}
                data-y={link.coords.y}
                data-z={link.coords.z}
              >
                {link.name}
              </a>
              <code class="coord" data-id={link.id}>{link.coords.formatted}</code>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <footer>
      {manifest.name} is one of the
      <a href="https://federatedplanets.com">Federated Planets</a> terraformed
      with
      <a href="https://github.com/Federated-Planets/planet">Source Codia</a>.
    </footer>
  </body>
</html>
